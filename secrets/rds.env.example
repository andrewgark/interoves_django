# Copy to secrets/rds.env and set RDS_PASSWORD. Do not commit secrets/rds.env.
#
#   cp secrets/rds.env.example secrets/rds.env

RDS_HOSTNAME=
RDS_PORT=3306
RDS_DB_NAME=ebdb
RDS_USERNAME=admin
RDS_PASSWORD=

# Optional: path to AWS RDS CA bundle (see secrets/README.md)
# MYSQL_SSL_CA=secrets/global-bundle.pem
