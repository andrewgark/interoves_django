# Copy to secrets/rds.env and set RDS_PASSWORD. Do not commit secrets/rds.env.
#
#   cp secrets/rds.env.example secrets/rds.env

RDS_HOSTNAME=
RDS_PORT=3306
RDS_DB_NAME=ebdb
RDS_USERNAME=admin
# Use single quotes so bash `source` works if the password has ( ) | $ [ ] etc.
RDS_PASSWORD='change-me'

# Same ARN as EB (`eb printenv` or agents/aws-eb.md). Lets Django load the real
# password via boto3 when you run ./scripts/with_rds.sh locally. Requires AWS
# credentials in that shell (e.g. aws sso login, AWS_PROFILE). If SM fails,
# Django falls back to RDS_PASSWORD — keep it set unless you always have creds.
# RDS_SECRET_ARN='arn:aws:secretsmanager:eu-central-1:ACCOUNT:secret:...'

# Optional: path to AWS RDS CA bundle (see secrets/README.md)
# MYSQL_SSL_CA=secrets/global-bundle.pem
