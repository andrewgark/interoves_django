# Copy to secrets/aws.env and adjust (never commit secrets/aws.env).
#
#   cp secrets/aws.env.example secrets/aws.env

export AWS_DEFAULT_REGION=eu-central-1

# Role for day-to-day AWS CLI / boto3 in this project (Cursor, local scripts).
export INTEROVES_AWS_ROLE_ARN=arn:aws:iam::916000456640:role/ai-bot

# Base credentials that may call sts:AssumeRole for INTEROVES_AWS_ROLE_ARN. Pick one:
# export AWS_PROFILE=default
# export AWS_PROFILE=my-sso-profile
# export AWS_ACCESS_KEY_ID=...
# export AWS_SECRET_ACCESS_KEY=...
