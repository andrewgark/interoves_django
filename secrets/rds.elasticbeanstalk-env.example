# Example RDS endpoint for Elastic Beanstalk env `interoves-env` (eu-central-1).
# Copy to secrets/rds.env, set RDS_PASSWORD, then: source secrets/rds.env
#
# Verify / update host with:
#   aws rds describe-db-instances --region eu-central-1 \
#     --query "DBInstances[?contains(DBInstanceIdentifier, \`rkvpj3bv2a\`)].Endpoint.Address" --output text

