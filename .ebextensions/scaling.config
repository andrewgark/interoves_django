# Load-balanced environment with scheduled capacity (Auto Scaling scheduled actions).
# Requires shared Redis (REDIS_HOST) for Django Channels — already set on interoves-env.
#
# Capacity (Europe/Moscow):
# - Sunday 17:00 → 3 instances (weekly peak window through end of Sunday)
# - Monday 00:00 → 1 instance (after Sunday 24:00 MSK)
# Other days stay at 1 until the next Sunday 17:00 action.
#
# Use only t3.small (or larger). t3.nano is too small for Django + Daphne.
#
# HealthCheckPath must use resource_name AWSEBV2LoadBalancerTargetGroup or EB ignores it.
option_settings:
  - namespace: aws:ec2:instances
    option_name: InstanceTypes
    value: t3.small
  - namespace: aws:elasticbeanstalk:environment
    option_name: EnvironmentType
    value: LoadBalanced
  - namespace: aws:elasticbeanstalk:environment:process:default
    option_name: HealthCheckPath
    resource_name: AWSEBV2LoadBalancerTargetGroup
    value: /health/
  # Baseline bounds; scheduled actions below set concrete min/max/desired each week.
  - namespace: aws:autoscaling:asg
    option_name: MinSize
    resource_name: AWSEBAutoScalingGroup
    value: '1'
  - namespace: aws:autoscaling:asg
    option_name: MaxSize
    resource_name: AWSEBAutoScalingGroup
    value: '3'

Resources:
  # Sunday 17:00 MSK → three instances until end of Sunday (see scale-in at Mon 00:00 MSK).
  InterovesScheduleSundayPeak:
    Type: AWS::AutoScaling::ScheduledAction
    Properties:
      AutoScalingGroupName:
        Ref: AWSEBAutoScalingGroup
      Recurrence: '0 17 * * SUN'
      TimeZone: Europe/Moscow
      MinSize: 3
      MaxSize: 3
      DesiredCapacity: 3

  # Monday 00:00 MSK = end of Sunday 24:00 — back to one instance for the rest of the week.
  InterovesScheduleWeekBaseline:
    Type: AWS::AutoScaling::ScheduledAction
    Properties:
      AutoScalingGroupName:
        Ref: AWSEBAutoScalingGroup
      Recurrence: '0 0 * * MON'
      TimeZone: Europe/Moscow
      MinSize: 1
      MaxSize: 1
      DesiredCapacity: 1
