packages:
  yum:
    atk: []
    at-spi2-atk: []
    cups-libs: []
    libdrm: []
    libXcomposite: []
    libXdamage: []
    libXrandr: []
    mesa-libgbm: []
    pango: []
    alsa-lib: []
    nss: []
    nspr: []
    libxkbcommon: []
    gtk3: []
    google-noto-emoji-color-fonts: []
    google-noto-emoji-fonts: []
    # Pillow ladder fallback needs Cyrillic glyphs (cron used to hit this path).
    dejavu-sans-fonts: []

container_commands:
  # Every instance: cron can run on any host; webapp HOME owns the browser cache.
  04_playwright_chromium:
    command: "source /var/app/venv/*/bin/activate && PLAYWRIGHT_BROWSERS_PATH=/home/webapp/.cache/ms-playwright python -m playwright install chromium && mkdir -p /home/webapp/.fonts && (cp -f /usr/share/fonts/google-noto-emoji/NotoColorEmoji.ttf /home/webapp/.fonts/ 2>/dev/null || cp -f /usr/share/fonts/noto/NotoColorEmoji.ttf /home/webapp/.fonts/ 2>/dev/null || true) && chown -R webapp:webapp /home/webapp/.cache/ms-playwright /home/webapp/.fonts || true"
