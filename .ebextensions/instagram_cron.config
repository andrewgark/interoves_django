# Daily cron to keep the long-lived Instagram token alive (03:17 MSK; EB instance TZ is MSK).
# The command self-gates (see instagram_refresh_token): it only calls the API when the stored
# token is older than ~30 days, so a daily schedule refreshes roughly monthly, well within the
# 60-day expiry. Script is installed via files: (not copied from /var/app/current).
files:
  "/opt/interoves/instagram_refresh.sh":
    mode: "000755"
    owner: root
    group: root
    content: |
      #!/bin/bash
      # Daily cron: refresh/seed the long-lived Instagram access token (DB-backed).
      set -euo pipefail
      APP_DIR=/var/app/current
      LOG=/var/log/instagram_refresh.log
      LOCK=/var/lock/instagram_refresh.lock
      exec 9>"$LOCK"
      if ! flock -n 9; then
        exit 0
      fi
      eval "$(/opt/elasticbeanstalk/bin/get-config environment | python3 -c '
      import json, shlex, sys
      env = json.load(sys.stdin)
      for key, value in env.items():
          print("export {}={}".format(key, shlex.quote(str(value))))
      ')"
      cd "$APP_DIR"
      # shellcheck disable=SC1091
      source /var/app/venv/*/bin/activate
      {
        echo "---- $(date -Is) instagram_refresh_token ----"
        python manage.py instagram_refresh_token
      } >>"$LOG" 2>&1

  "/etc/cron.d/interoves-instagram-refresh":
    mode: "000644"
    owner: root
    group: root
    content: |
      SHELL=/bin/bash
      PATH=/sbin:/bin:/usr/sbin:/usr/bin
      17 3 * * * root /opt/interoves/instagram_refresh.sh

commands:
  01_instagram_refresh_log:
    command: "touch /var/log/instagram_refresh.log && chmod 644 /var/log/instagram_refresh.log"
