container_commands:
  01_migrate:
    command: "source /var/app/venv/*/bin/activate && python3 manage.py migrate --noinput --verbosity 2"
    leader_only: true
  02_createsu:
    command: "source /var/app/venv/*/bin/activate && python3 manage.py createsu"
    leader_only: true
  # Leader only: uploads to S3 (USE_S3); avoids OOM on t3.nano followers during parallel deploys.
  03_collectstatic:
    command: "source /var/app/venv/*/bin/activate && python3 manage.py collectstatic --noinput"
    leader_only: true


option_settings:
  # Default is 600s; EB maximum is 3600s.
  aws:elasticbeanstalk:command:
    Timeout: 3600
  aws:elasticbeanstalk:container:python:
    WSGIPath: interoves_django.asgi:application
  aws:elasticbeanstalk:application:environment:
    DJANGO_SETTINGS_MODULE: interoves_django.settings
    DEBUG_ON: FALSE
    IS_PROD: TRUE
    USE_S3: TRUE
    RDS_SECRET_ARN: "arn:aws:secretsmanager:eu-central-1:916000456640:secret:rds!db-ce1a594a-9964-4a32-a9d3-9483ada5368c-0O6ead"
