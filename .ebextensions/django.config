container_commands:
  01_migrate:
    command: "source /var/app/venv/*/bin/activate && python3 manage.py migrate --noinput --verbosity 2"
    leader_only: true
  02_createsu:
    command: "source /var/app/venv/*/bin/activate && python3 manage.py createsu"
    leader_only: true
  # Leader only: uploads to S3 (USE_S3); avoids OOM on t3.nano followers during parallel deploys.
  03_collectstatic:
    command: "source /var/app/venv/*/bin/activate && python3 manage.py collectstatic --noinput"
    leader_only: true


option_settings:
  # Default is 600s; EB maximum is 3600s.
  aws:elasticbeanstalk:command:
    Timeout: 3600
  aws:elasticbeanstalk:container:python:
    WSGIPath: interoves_django.asgi:application
  aws:elasticbeanstalk:application:environment:
    DJANGO_SETTINGS_MODULE: interoves_django.settings
    DEBUG_ON: FALSE
    IS_PROD: TRUE
    USE_S3: TRUE
    # Eurovision booklet 2026: frozen at PINNED_REF (no main tip polling / auto-updates).
    # AUTO_SYNC=FALSE + pin: at most a one-time fill of empty var/ from that commit.
    # Optional: eb setenv EUROVISION_BOOKLET_GITHUB_TOKEN=... (PAT) for API limits on first fill.
    EUROVISION_BOOKLET_GITHUB_REPO: "andrewgark/eurovision2026booklet"
    EUROVISION_BOOKLET_GIT_BRANCH: "main"
    EUROVISION_BOOKLET_PINNED_REF: "23be3106b745af459479f9f3d97579e74ecbe939"
    EUROVISION_BOOKLET_AUTO_SYNC: "FALSE"
    EUROVISION_BOOKLET_DIST_PATH: "dist"
    EUROVISION_BOOKLET_HTTP_TIMEOUT: "60"
    EUROVISION_BOOKLET_SYNC_MIN_INTERVAL_SEC: "120"
    RDS_SECRET_ARN: "arn:aws:secretsmanager:eu-central-1:916000456640:secret:rds!db-ce1a594a-9964-4a32-a9d3-9483ada5368c-0O6ead"
