# Minute cron for Telegram game announcements + daily ladder channel schedule (00:15 MSK).
# Django uses Europe/Moscow for the window; EB instance TZ is MSK.
files:
  "/etc/cron.d/interoves-telegram":
    mode: "000644"
    owner: root
    group: root
    content: |
      SHELL=/bin/bash
      PATH=/sbin:/bin:/usr/sbin:/usr/bin
      * * * * * root /opt/interoves/telegram_cron.sh

container_commands:
  05_telegram_cron:
    command: "mkdir -p /opt/interoves && cp -f /var/app/current/scripts/telegram_cron.sh /opt/interoves/telegram_cron.sh && chmod 755 /opt/interoves/telegram_cron.sh && touch /var/log/telegram_cron.log && chmod 644 /var/log/telegram_cron.log"
