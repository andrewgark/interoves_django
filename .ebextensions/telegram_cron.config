# Minute cron for Telegram game announcements + daily ladder channel schedule (00:15 MSK).
# Django uses Europe/Moscow for the window; EB instance TZ is MSK.
# Script is installed via files: (not copied from /var/app/current — that path is
# not ready yet during container_commands / PostBuild).
files:
  "/opt/interoves/telegram_cron.sh":
    mode: "000755"
    owner: root
    group: root
    content: |
      #!/bin/bash
      # Minute cron: Telegram announcements + ladder channel tick (00:15 MSK).
      set -euo pipefail
      APP_DIR=/var/app/current
      LOG=/var/log/telegram_cron.log
      LOCK=/var/lock/telegram_cron.lock
      exec 9>"$LOCK"
      if ! flock -n 9; then
        exit 0
      fi
      eval "$(/opt/elasticbeanstalk/bin/get-config environment | python3 -c '
      import json, shlex, sys
      env = json.load(sys.stdin)
      for key, value in env.items():
          print("export {}={}".format(key, shlex.quote(str(value))))
      ')"
      cd "$APP_DIR"
      # shellcheck disable=SC1091
      source /var/app/venv/*/bin/activate
      # Cron runs as root; Playwright Chromium lives under webapp (playwright.config).
      # Without this path, ladder screenshots fall back to Pillow (broken Cyrillic).
      export PLAYWRIGHT_BROWSERS_PATH="${PLAYWRIGHT_BROWSERS_PATH:-/home/webapp/.cache/ms-playwright}"
      {
        echo "---- $(date -Is) telegram_game_announcements ----"
        python manage.py telegram_game_announcements
      } >>"$LOG" 2>&1

  "/etc/cron.d/interoves-telegram":
    mode: "000644"
    owner: root
    group: root
    content: |
      SHELL=/bin/bash
      PATH=/sbin:/bin:/usr/sbin:/usr/bin
      * * * * * root /opt/interoves/telegram_cron.sh

commands:
  01_telegram_cron_log:
    command: "touch /var/log/telegram_cron.log && chmod 644 /var/log/telegram_cron.log"
