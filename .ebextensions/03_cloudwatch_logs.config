# CloudWatch Logs: retention is in whole days only (AWS has no "hours" setting).
# 1 day keeps cost/storage down; raise to 7/14/30 if you need longer history for deploy debugging.
option_settings:
  aws:elasticbeanstalk:cloudwatch:logs:
    StreamLogs: true
    DeleteOnTerminate: false
    RetentionInDays: 1
